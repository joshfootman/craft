---
import { load_studies } from "~/lib/studies";
import type { Meta } from "~/types/study";

const glob_result = import.meta.glob<{ meta: Meta }>(
  "/src/pages/studies/**/_meta.ts",
  { eager: true },
);
const studies = load_studies(glob_result);
const first = studies[0];

return Astro.redirect(first ? `/studies/${first.id}` : "/404");
---
