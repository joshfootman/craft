---
import "~/styles/global.css";
import { loadStudies } from "~/lib/studies";
import { HubHeader } from "~/components/hub-header";
import { Hub } from "~/components/hub";
import type { Meta } from "~/types/study";

const globResults = import.meta.glob<{ meta: Meta }>(
  "/src/pages/studies/**/_meta.ts",
  { eager: true },
);
const studies = loadStudies(globResults);
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>Craft</title>
  </head>
  <body class="flex h-screen flex-col">
    <HubHeader studies={studies} client:load />
    <main class="flex-1 overflow-auto">
      <Hub studies={studies} client:load />
    </main>
  </body>
</html>
